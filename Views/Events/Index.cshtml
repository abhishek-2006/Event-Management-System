@model IEnumerable<EventManagementSystem.Models.Event>

@{
    ViewData["Title"] = "Available Events";
}

<div class="py-8">
    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white">Campus Events</h2>
            <p class="text-slate-600 dark:text-slate-400 mt-1">Discover and register for upcoming college activities.</p>
        </div>
        
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Create" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-blue-500/25">
                + Create Event
            </a>
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var item in Model)
        {
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-5 hover:shadow-xl transition-all group flex flex-col">
                <div class="flex justify-between items-start mb-4">
                    <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs font-bold rounded-full">
                        @item.Category
                    </span>
                    <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">
                        @item.EventDate.ToShortDateString()
                    </span>
                </div>
                
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">@item.Title</h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 line-clamp-2">@item.Description</p>

                <div class="flex gap-3 mt-auto">
                    <a asp-action="Register" asp-route-slug="@item.Slug" class="flex-1 text-center py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all">
                        Register Now
                    </a>
                    
                    @if (User.Identity.IsAuthenticated) {
                        <a asp-action="Edit" asp-route-slug="@item.Slug" class="px-4 py-2.5 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-xl hover:bg-slate-200 transition-colors">
                           Edit
                        </a>
                    }
                </div>
            </div>
            }
    </div>
</div>