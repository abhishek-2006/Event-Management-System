@model EventManagementSystem.Models.Registration

@{
    ViewData["Title"] = "Event Registration";
}

<div class="max-w-2xl mx-auto py-12 px-4">
    <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-2xl border border-slate-100 dark:border-slate-700">
        <div class="mb-8">
            <h2 class="text-3xl font-black text-slate-900 dark:text-white">Register</h2>
            <p class="text-blue-600 dark:text-blue-400 font-bold">@ViewBag.EventTitle</p>
        </div>

        <form asp-action="Register" method="post" class="space-y-6">
            <input type="hidden" asp-for="EventId" />

            <div>
                <label asp-for="StudentName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2 italic">Full Name</label>
                <input asp-for="StudentName" placeholder="e.g. Abhishek Shah" 
                       class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                <span asp-validation-for="StudentName" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="RollNumber" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2 italic">Roll Number</label>
                    <input asp-for="RollNumber" placeholder="e.g. 101" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                    <span asp-validation-for="RollNumber" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2 italic">Email Address</label>
                    <input asp-for="Email" placeholder="student@example.com" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <button type="submit" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 transition-all transform hover:-translate-y-1">
                Confirm Registration
            </button>
        </form>
    </div>
</div>