@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Event Management System</title>
    
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { primary: '#3b82f6' }
                }
            }
        }
    </script>
</head>
<body class="bg-white text-slate-900 dark:bg-slate-900 dark:text-white transition-colors duration-300 flex flex-col min-h-screen">
    
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 shadow-sm">
        <nav class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <a href="/" class="flex items-center gap-2 group">
                    <div class="p-2 bg-blue-600 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <span class="font-bold text-xl tracking-tight text-slate-900 dark:text-white">
                        Event<span class="text-blue-600 dark:text-blue-400">Hub</span>
                    </span>
                </a>

                <div class="hidden md:flex items-center gap-6">
                    <div class="flex gap-1 text-sm font-semibold">
                        <a asp-controller="Home" asp-action="Index" 
                           class="px-4 py-2 rounded-lg transition-all duration-200 @(currentController == "Home" && currentAction == "Index" ? "bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400" : "text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-blue-600")">
                           Home
                        </a>
                        <a asp-controller="Events" asp-action="Index" 
                           class="px-4 py-2 rounded-lg transition-all duration-200 @(currentController == "Events" ? "bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400" : "text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-blue-600")">
                           Browse Events
                        </a>
                        <a asp-controller="Home" asp-action="Contact" 
                           class="px-4 py-2 rounded-lg transition-all duration-200 @(currentController == "Home" && currentAction == "Contact" ? "bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400" : "text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-blue-600")">
                           Contact
                        </a>
                    </div>
                    
                    <div class="flex items-center gap-4 border-l border-slate-200 dark:border-slate-700 pl-6">
                        <button id="theme-toggle" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-transparent hover:border-blue-500 transition-all">
                            <span class="dark:hidden">🌙</span>
                            <span class="hidden dark:inline">☀️</span>
                        </button>
                    </div>
                </div>

                <button id="mobile-menu-button" class="md:hidden p-2 text-slate-600 dark:text-slate-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </div>
            
            <div id="mobile-menu" class="hidden md:hidden mt-4 space-y-2 border-t border-slate-100 dark:border-slate-800 pt-4">
                <a asp-controller="Home" asp-action="Index" class="block px-4 py-2 rounded-lg @(currentController == "Home" && currentAction == "Index" ? "bg-blue-50 text-blue-600" : "")">Home</a>
                <a asp-controller="Events" asp-action="Index" class="block px-4 py-2 rounded-lg @(currentController == "Events" ? "bg-blue-50 text-blue-600" : "")">Browse Events</a>
                <a asp-controller="Home" asp-action="Contact" class="block px-4 py-2 rounded-lg @(currentController == "Home" && currentAction == "Contact" ? "bg-blue-50 text-blue-600" : "")">Contact</a>
            </div>
        </nav>
    </header>

    <main class="container mx-auto px-4 py-8 flex-grow">
        @RenderBody()
    </main>

    <footer class="mt-20 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 transition-colors duration-300">
        <div class="container mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center mb-12">
                <div class="flex flex-col items-center md:items-start">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="p-1.5 bg-blue-600 rounded-lg shadow-lg shadow-blue-500/20">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                        <span class="font-bold text-xl text-slate-900 dark:text-white tracking-tight">Event<span class="text-blue-600">Hub</span></span>
                    </div>
                    <p class="text-sm text-slate-500 dark:text-slate-400 text-center md:text-left leading-relaxed">
                        Designed for students to explore and participate in campus activities.
                    </p>
                </div>

                <div class="flex justify-center gap-10 text-sm font-medium text-slate-600 dark:text-slate-300">
                    <a asp-controller="Home" asp-action="Index" class="hover:text-blue-600 transition-colors">Home</a>
                    <a asp-controller="Events" asp-action="Index" class="hover:text-blue-600 transition-colors">All Events</a>
                    <a asp-controller="Home" asp-action="Contact" class="hover:text-blue-600 transition-colors">Support</a>
                </div>

                <div class="flex flex-col items-center md:items-end">
                    <a href="/Admin/Login" class="group flex items-center gap-2 px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-blue-600 dark:text-slate-500 dark:hover:text-blue-400 transition-all border border-slate-200 dark:border-slate-700 rounded-lg hover:border-blue-600">
                        <svg class="w-3.5 h-3.5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        Admin Access
                    </a>
                </div>
            </div>

            <div class="border-t border-slate-200/60 dark:border-slate-800/60 pt-8 flex flex-col items-center">
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] text-center">
                    Made by 
                    <a href="https://abhishekshah-portfolio.vercel.app/" target="_blank" class="text-slate-900 dark:text-slate-200 hover:text-blue-600 transition-colors">
                        Abhishek Shah
                    </a>
                </p>
                <p class="text-[10px] text-slate-400 dark:text-slate-600 text-center mt-2 uppercase tracking-widest">
                    © 2026 EMS Project
                </p>
            </div>
        </div>
    </footer>

    <script>
        const html = document.documentElement;
        const themeBtn = document.getElementById('theme-toggle');
        const mobileMenuBtn = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');

        // Theme Toggle
        themeBtn.addEventListener('click', () => {
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                html.classList.add('dark');
                localStorage.theme = 'dark';
            }
        });

        // Mobile Menu
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Init Theme
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            html.classList.add('dark');
        } else {
            html.classList.remove('dark');
        }
    </script>
</body>
</html>