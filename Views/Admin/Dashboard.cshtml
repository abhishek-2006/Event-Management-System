@{
    ViewData["Title"] = "Admin Dashboard";
    var totalEvents = ViewBag.TotalEvents ?? 0;
    var totalRegistrations = ViewBag.TotalRegistrations ?? 0;
}

<div class="max-w-7xl mx-auto py-10 px-6">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-blue-600 to-indigo-700 p-8 md:p-12 mb-10 shadow-2xl shadow-blue-500/20">
        <div class="relative z-10">
            <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight">
                Welcome, @Context.Session.GetString("Admin")! 👋
            </h2>
            <p class="text-blue-100 mt-3 text-lg font-medium max-w-xl opacity-90">
                Manage your campus ecosystem, track student engagement, and launch new experiences from your command center.
            </p>
        </div>
        <div class="absolute -right-10 -top-10 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="group bg-white dark:bg-slate-800 p-6 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                    📅
                </div>
                <span class="text-xs font-bold text-emerald-500 bg-emerald-50 dark:bg-emerald-900/30 px-2 py-1 rounded-lg">+@totalEvents New</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm font-bold uppercase tracking-widest">Active Events</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">@totalEvents</h3>
        </div>

        <div class="group bg-white dark:bg-slate-800 p-6 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                    👥
                </div>
                <span class="text-xs font-bold text-purple-500 bg-purple-50 dark:bg-purple-900/30 px-2 py-1 rounded-lg">Live</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm font-bold uppercase tracking-widest">Total Attendees</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">@totalRegistrations</h3>
        </div>

        <div class="group bg-white dark:bg-slate-800 p-6 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                    ⭐
                </div>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm font-bold uppercase tracking-widest">Avg. Rating</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">4.8</h3>
        </div>

        <div class="group bg-white dark:bg-slate-800 p-6 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                    🛡️
                </div>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm font-bold uppercase tracking-widest">Admin Role</p>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mt-3 uppercase tracking-tighter">Super Admin</h3>
        </div>
    </div>

    <div class="flex items-center gap-2 mb-8 px-1">
        <div class="h-8 w-1.5 bg-blue-600 rounded-full"></div>
        <h3 class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight">Quick Operations</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <a href="/Admin/CreateEvent" class="group relative block p-8 bg-white dark:bg-slate-800 rounded-[2rem] border-2 border-transparent hover:border-blue-500 transition-all shadow-lg hover:shadow-blue-500/10 overflow-hidden">
            <div class="relative z-10">
                <div class="text-4xl mb-4 group-hover:rotate-12 transition-transform inline-block">✨</div>
                <h4 class="text-xl font-bold text-slate-900 dark:text-white">Create New Event</h4>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-2 leading-relaxed">Launch your next workshop or seminar with our intuitive event builder.</p>
                <div class="mt-6 flex items-center text-blue-600 font-bold text-sm">
                    Get Started <span class="ml-2 group-hover:translate-x-2 transition-transform">&rarr;</span>
                </div>
            </div>
            <div class="absolute -right-4 -bottom-4 text-8xl opacity-[0.03] dark:opacity-[0.05] font-black italic">NEW</div>
        </a>

        <a href="/Admin/Events" class="group relative block p-8 bg-white dark:bg-slate-800 rounded-[2rem] border-2 border-transparent hover:border-purple-500 transition-all shadow-lg hover:shadow-purple-500/10 overflow-hidden">
            <div class="relative z-10">
                <div class="text-4xl mb-4 group-hover:scale-110 transition-transform inline-block">⚙️</div>
                <h4 class="text-xl font-bold text-slate-900 dark:text-white">Control Center</h4>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-2 leading-relaxed">Modify dates, update descriptions, or manage event status effortlessly.</p>
                <div class="mt-6 flex items-center text-purple-600 font-bold text-sm">
                    Manage Events <span class="ml-2 group-hover:translate-x-2 transition-transform">&rarr;</span>
                </div>
            </div>
            <div class="absolute -right-4 -bottom-4 text-8xl opacity-[0.03] dark:opacity-[0.05] font-black italic">LIST</div>
        </a>

        <a href="/Admin/Registrations" class="group relative block p-8 bg-white dark:bg-slate-800 rounded-[2rem] border-2 border-transparent hover:border-amber-500 transition-all shadow-lg hover:shadow-amber-500/10 overflow-hidden">
            <div class="relative z-10">
                <div class="text-4xl mb-4 group-hover:-rotate-12 transition-transform inline-block">📋</div>
                <h4 class="text-xl font-bold text-slate-900 dark:text-white">Attendee Insights</h4>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-2 leading-relaxed">View student lists, verify roll numbers, and track registration trends.</p>
                <div class="mt-6 flex items-center text-amber-600 font-bold text-sm">
                    View Records <span class="ml-2 group-hover:translate-x-2 transition-transform">&rarr;</span>
                </div>
            </div>
            <div class="absolute -right-4 -bottom-4 text-8xl opacity-[0.03] dark:opacity-[0.05] font-black italic">DATA</div>
        </a>

    </div>
</div>